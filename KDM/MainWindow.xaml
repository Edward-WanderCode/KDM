<Window x:Class="KDM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:KDM.UI"
        xmlns:conv="clr-namespace:KDM.UI.Converters"
        Title="{DynamicResource AppTitle}"
        Icon="Assets/app_icon.ico"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#C9D1D9">

    <Window.DataContext>
        <ui:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToIconConverter x:Key="StatusToIcon"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Màu sắc chủ đạo -->
        <Color x:Key="BgDark">#0D1117</Color>
        <Color x:Key="BgCard">#161B22</Color>
        <Color x:Key="BgHover">#21262D</Color>
        <Color x:Key="BorderColor">#30363D</Color>
        <Color x:Key="AccentBlue">#58A6FF</Color>
        <Color x:Key="AccentGreen">#3FB950</Color>
        <Color x:Key="TextPrimary">#C9D1D9</Color>
        <Color x:Key="TextSecondary">#8B949E</Color>

        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Style cho TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#161B22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Accent Button (nút chính) -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1B6D2F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#F85149"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#490202"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D0101"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ProgressBar style -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" 
                                    CornerRadius="3"
                                    HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#238636" Offset="0"/>
                                        <GradientStop Color="#3FB950" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox ToggleButton -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="6"
                        Background="#0D1117" BorderBrush="#30363D" BorderThickness="1"/>
                <Border Grid.Column="0" CornerRadius="6,0,0,6" Margin="1" Background="Transparent"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="#8B949E" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#484F58"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#C9D1D9"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#58A6FF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#161B22" BorderBrush="#30363D"
                                            BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="4" Opacity="0.4" BlurRadius="8" Color="Black"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="2,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F3A5F"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header / Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Add URL panel -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>       <!-- Download list -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- HEADER -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬇" FontSize="22" Foreground="#58A6FF" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="KDM" FontSize="20" FontWeight="Bold" Foreground="#C9D1D9" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DownloadManager}" FontSize="14" Foreground="#8B949E" Margin="8,0,0,2" VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- Tổng speed + active count -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#0D1117" CornerRadius="6" Padding="12,6" Margin="0,0,8,0"
                            Visibility="{Binding TotalSpeedText, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓" Foreground="#3FB950" FontWeight="Bold" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding TotalSpeedText}" Foreground="#3FB950" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1117" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource ActiveDownloads}" Foreground="#8B949E" Margin="0,0,4,0" FontSize="12"/>
                            <TextBlock Text="{Binding ActiveCount}" Foreground="#58A6FF" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <!-- Nút đổi ngôn ngữ -->
                    <Button Style="{StaticResource ModernButton}" 
                            Content="{DynamicResource LangToggle}"
                            Click="ToggleLanguage_Click"
                            Margin="8,0,0,0" Padding="8,6" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- ADD URL PANEL -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: URL input -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding NewUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{DynamicResource UrlPlaceholder}"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center">
                        <!-- Placeholder text -->
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Column="1"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding AddDownloadCommand}"
                            MinWidth="140">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource AddDownload}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Row 2: Save directory + thread count -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource SaveTo}" Foreground="#8B949E" 
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                        <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SaveDirectory}" FontSize="12"/>
                        <Button Grid.Column="2" Style="{StaticResource ModernButton}" Content="..."
                                Command="{Binding BrowseFolderCommand}" Margin="6,0,0,0"
                                Padding="10,8" MinWidth="36"/>
                    </Grid>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{DynamicResource Threads}" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                        <ComboBox Width="75" SelectedItem="{Binding ThreadCount}"
                                  Style="{StaticResource DarkComboBox}">
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">1</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">2</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">4</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">8</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">32</sys:Int32>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TOOLBAR -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D1117" Padding="20,8" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ModernButton}" Command="{Binding PauseCommand}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnPause}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButton}" Command="{Binding ResumeCommand}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnResume}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnDelete}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Background="#30363D" Margin="10,2"/>

                <Button Style="{StaticResource ModernButton}" Command="{Binding PauseAllCommand}" Margin="10,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnPauseAll}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButton}" Command="{Binding ResumeAllCommand}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnResumeAll}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Background="#30363D" Margin="10,2"/>

                <Button Style="{StaticResource ModernButton}" Command="{Binding OpenFileLocationCommand}" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8DA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnOpenFolder}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- DOWNLOAD LIST -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0D1117" Padding="0">
            <Grid>
                <!-- Header row -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Border Grid.Row="0" Background="#161B22" Padding="20,10" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>     <!-- Icon -->
                            <ColumnDefinition Width="*"/>       <!-- File name -->
                            <ColumnDefinition Width="200"/>     <!-- Progress -->
                            <ColumnDefinition Width="100"/>     <!-- Speed -->
                            <ColumnDefinition Width="120"/>     <!-- Size -->
                            <ColumnDefinition Width="70"/>      <!-- ETA -->
                            <ColumnDefinition Width="100"/>     <!-- Status -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="" Foreground="#8B949E" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource ColFileName}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource ColProgress}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="10,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="{DynamicResource ColSpeed}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="{DynamicResource ColSize}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="{DynamicResource ColEta}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="{DynamicResource ColStatus}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- List -->
                <ListBox Grid.Row="1"
                         x:Name="DownloadListBox"
                         ItemsSource="{Binding Downloads}"
                         SelectedItem="{Binding SelectedItem}"
                         SelectionMode="Extended"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">

                    <!-- Context Menu (Dark Theme) -->
                    <ListBox.ContextMenu>
                        <ContextMenu Background="#1C2128" BorderBrush="#30363D" BorderThickness="1" Foreground="#C9D1D9">
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#30363D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="Separator">
                                    <Setter Property="Background" Value="#30363D"/>
                                    <Setter Property="Margin" Value="4,2"/>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem Click="CtxOpenFile_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Mở file / Open File" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="CtxOpenFolder_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8DA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Mở thư mục / Open Folder" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Click="CtxCopyUrl_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Sao chép URL / Copy URL" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Click="CtxPause_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Tạm dừng / Pause" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="CtxResume_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Tiếp tục / Resume" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Click="CtxDelete_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#F85149"/>
                                        <TextBlock Text="Xóa / Delete" VerticalAlignment="Center" Foreground="#F85149"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                BorderBrush="#30363D"
                                                BorderThickness="0,0,0,1"
                                                Padding="20,12">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#161B22"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#58A6FF"/>
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2,0,0,1"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#0E1419"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>     <!-- Icon -->
                                    <ColumnDefinition Width="*"/>       <!-- File name -->
                                    <ColumnDefinition Width="200"/>     <!-- Progress -->
                                    <ColumnDefinition Width="100"/>     <!-- Speed -->
                                    <ColumnDefinition Width="120"/>     <!-- Size -->
                                    <ColumnDefinition Width="70"/>      <!-- ETA -->
                                    <ColumnDefinition Width="100"/>     <!-- Status -->
                                </Grid.ColumnDefinitions>

                                <!-- Status icon -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                           FontSize="16" VerticalAlignment="Center"/>

                                <!-- File name -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" 
                                               Foreground="#C9D1D9" FontSize="13" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ThreadsText}" 
                                               Foreground="#484F58" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Progress bar + percentage -->
                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ProgressBar Grid.Row="0"
                                                 Value="{Binding Progress, Mode=OneWay}"
                                                 Maximum="100"
                                                 Style="{StaticResource ModernProgressBar}"
                                                 Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Progress, StringFormat='{}{0:F1}%'}"
                                               Foreground="#8B949E" FontSize="10" Margin="0,3,0,0"/>
                                </Grid>

                                <!-- Speed -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding SpeedText}"
                                           Foreground="#3FB950" FontSize="12" FontWeight="SemiBold"
                                           TextAlignment="Right" VerticalAlignment="Center"/>

                                <!-- Size -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding SizeText}"
                                           Foreground="#8B949E" FontSize="12"
                                           TextAlignment="Right" VerticalAlignment="Center"/>

                                <!-- ETA -->
                                <TextBlock Grid.Column="5"
                                           Text="{Binding EtaText}"
                                           Foreground="#8B949E" FontSize="12"
                                           TextAlignment="Right" VerticalAlignment="Center"/>

                                <!-- Status -->
                                <Border Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        CornerRadius="10" Padding="8,3"
                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        Opacity="0.15">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               FontSize="11" FontWeight="SemiBold"
                                               TextAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" 
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Downloads.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <TextBlock Text="{DynamicResource NoDownloadsIcon}" FontSize="48" Foreground="#21262D" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource NoDownloadsTitle}" Foreground="#484F58" FontSize="16" 
                               Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource NoDownloadsSub}" Foreground="#30363D" FontSize="13"
                               Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- STATUS BAR -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <TextBlock Text="{Binding StatusBarText}" Foreground="#8B949E" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Text="KDM v1.0 • Multi-thread Download Manager"
                           Foreground="#30363D" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
